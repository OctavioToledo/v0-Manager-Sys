# Base de datos — Supabase PostgreSQL
DB_URL=jdbc:postgresql://<host>.pooler.supabase.com:6543/postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=

# Auth0 (reemplazar por Supabase Auth en SMS-28)
AUTH0_ISSUER_URI=https://<tenant>.us.auth0.com/
AUTH0_JWK_SET_URI=https://<tenant>.us.auth0.com/.well-known/jwks.json/
AUTH0_AUDIENCE=omtimeAPI

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://om-time.vercel.app

# JWT local (eliminar en SMS-28)
JWT_SECRET=
